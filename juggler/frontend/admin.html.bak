<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Админ-панель - JUGGLER</title>
		<link rel="stylesheet" href="css/admin.css" />
		<link
			href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css"
			rel="stylesheet"
		/>
		<link
			rel="icon"
			href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎪</text></svg>"
		/>
		<script src="js/auth.js"></script>
		<script>
			// Check authentication before loading page
			checkAuth()
		</script>
	</head>
	<body>
		<button class="burger-btn" onclick="toggleSidebar()">☰</button>
		<div class="admin-container">
			<aside class="sidebar">
				<div class="sidebar-header">
					<h1>JUGGLER<span> ADMIN</span></h1>
				</div>
				<nav class="sidebar-nav">
					<a href="#" class="nav-item active" data-section="dashboard">
						<span class="icon">📊</span>
						<span class="text">Дашборд</span>
					</a>
					<a href="#" class="nav-item" data-section="videos">
						<span class="icon">🎥</span>
						<span class="text">Видео</span>
					</a>
					<a href="#" class="nav-item" data-section="photos">
						<span class="icon">📸</span>
						<span class="text">Фотогалерея</span>
					</a>

					<a href="#" class="nav-item" data-section="social">
						<span class="icon">📱</span>
						<span class="text">Соцсети</span>
					</a>
					<a href="#" class="nav-item" data-section="tickets">
						<span class="icon">🎫</span>
						<span class="text">Билеты</span>
					</a>
					<a href="#" class="nav-item" data-section="contactforms">
						<span class="icon">✉️</span>
						<span class="text">Заявки</span>
					</a>

					<a href="#" class="nav-item" data-section="stats">
						<span class="icon">📈</span>
						<span class="text">Статистика</span>
					</a>
					<a href="#" class="nav-item" data-section="backup">
						<span class="icon">💾</span>
						<span class="text">Бэкап</span>
					</a>
				</nav>
				<div class="sidebar-footer">
					<a href="index.html" class="back-btn">← Вернуться на сайт</a>
				</div>
			</aside>

			<main class="main-content">
				<header class="top-bar">
					<h2 id="pageTitle">Панель управления</h2>
					<div class="user-info">
						<span>Администратор</span>
						<div class="avatar">👤</div>
						<button
							onclick="logout()"
							class="btn-icon"
							style="margin-left: 15px; color: #ff4444"
							title="Выйти"
						>
							🚪
						</button>
					</div>
				</header>

				<!-- Dashboard Section -->
				<section id="dashboard" class="content-section active">
					<div class="stats-grid">
						<div class="stat-card" onclick="navigateToSection('videos')">
							<div class="stat-icon">🎥</div>
							<div class="stat-info">
								<h3>Видео</h3>
								<p class="stat-number" id="videoCount">0</p>
							</div>
						</div>
						<div class="stat-card" onclick="navigateToSection('photos')">
							<div class="stat-icon">📸</div>
							<div class="stat-info">
								<h3>Фото</h3>
								<p class="stat-number" id="photoCount">0</p>
							</div>
						</div>
						<div class="stat-card" onclick="navigateToSection('events')">
							<div class="stat-icon">🎭</div>
							<div class="stat-info">
								<h3>События</h3>
								<p class="stat-number" id="eventCount">0</p>
							</div>
						</div>
						<div class="stat-card" onclick="navigateToSection('stats')">
							<div class="stat-icon">👁️</div>
							<div class="stat-info">
								<h3>Посещения</h3>
								<p class="stat-number" id="visitCount">0</p>
							</div>
						</div>
					</div>

					<div class="welcome-card">
						<h3>Добро пожаловать в панель управления!</h3>
						<p>Здесь вы можете управлять всем контентом сайта JUGGLER.</p>
					</div>
				</section>

				<!-- Videos Section -->
				<section id="videos" class="content-section">
					<div class="section-header">
						<h3>Управление видео</h3>
						<div class="timer-control">
							<span class="timer-icon">⏱</span>
							<span class="timer-label">Слайд:</span>
							<input
								type="number"
								id="videoSlideDuration"
								value="5"
								min="1"
								onchange="saveDurationSetting('video', this.value)"
							/>
							<span class="timer-unit">сек</span>
						</div>
						<button class="btn btn-primary" onclick="showAddVideoForm()">
							+ Добавить видео
						</button>
					</div>

					<div id="addVideoForm" class="form-container" style="display: none">
						<h4>Добавить/Редактировать видео</h4>
						<form onsubmit="saveVideo(event)">
							<input type="hidden" id="videoId" />
							<div class="form-group">
								<label>Название</label>
								<input
									type="text"
									id="videoTitle"
									required
									placeholder="Название видео"
								/>
							</div>
							<div class="form-group">
								<label>Описание</label>
								<textarea
									id="videoDescription"
									placeholder="Описание видео"
								></textarea>
							</div>
							<div class="form-group">
								<label>Длительность (мин:сек)</label>
								<div style="display: flex; gap: 10px; align-items: center">
									<select id="videoDurationMin" style="width: 80px">
										<option value="0">0</option>
										<option value="1">1</option>
										<option value="2">2</option>
										<option value="3">3</option>
										<option value="4">4</option>
										<option value="5">5</option>
										<option value="6">6</option>
										<option value="7">7</option>
										<option value="8">8</option>
										<option value="9">9</option>
										<option value="10">10</option>
									</select>
									<span>:</span>
									<select id="videoDurationSec" style="width: 80px">
										<option value="00">00</option>
										<option value="15">15</option>
										<option value="30">30</option>
										<option value="45">45</option>
									</select>
									<input type="hidden" id="videoDuration" />
								</div>
							</div>
							<div class="form-group">
								<label>Файл видео (или URL)</label>
								<input type="file" id="videoFile" accept="video/*" />
								<input
									type="text"
									id="videoUrl"
									placeholder="Или ссылка на видео"
								/>
								<small>Если выбран файл, URL будет проигнорирован.</small>
							</div>
							<div class="form-actions">
								<button type="submit" class="btn btn-primary">Сохранить</button>
								<button
									type="button"
									class="btn btn-secondary"
									onclick="hideAddVideoForm()"
								>
									Отмена
								</button>
							</div>
						</form>
					</div>

					<div class="table-container">
						<table class="data-table">
							<thead>
								<tr>
									<th>Название</th>
									<th>Описание</th>
									<th>Длительность</th>
									<th>Действия</th>
								</tr>
							</thead>
							<tbody id="videosTableBody">
								<!-- Videos will be loaded here -->
							</tbody>
						</table>
					</div>
				</section>

				<!-- Photos Section -->
				<section id="photos" class="content-section">
					<div class="section-header">
						<h3>Управление фотогалереей</h3>
						<div class="timer-control">
							<span class="timer-icon">⏱</span>
							<span class="timer-label">Слайд:</span>
							<input
								type="number"
								id="photoSlideDuration"
								value="5"
								min="1"
								onchange="saveDurationSetting('photo', this.value)"
							/>
							<span class="timer-unit">сек</span>
						</div>
						<button class="btn btn-primary" onclick="showAddPhotoForm()">
							+ Добавить фото
						</button>
					</div>

					<div id="addPhotoForm" class="form-container" style="display: none">
						<h4>Добавить/Редактировать фото</h4>
						<form onsubmit="savePhoto(event)">
							<input type="hidden" id="photoId" />
							<div class="form-group">
								<label>Заголовок</label>
								<input
									type="text"
									id="photoTitle"
									required
									placeholder="Заголовок фото"
								/>
							</div>
							<div class="form-group">
								<label>Описание</label>
								<textarea
									id="photoDescription"
									placeholder="Описание фото"
								></textarea>
							</div>
							<div class="form-group">
								<label>Изображение</label>
								<input type="file" id="photoFile" accept="image/*" />
							</div>
							<div class="form-actions">
								<button type="submit" class="btn btn-primary">Сохранить</button>
								<button
									type="button"
									class="btn btn-secondary"
									onclick="hideAddPhotoForm()"
								>
									Отмена
								</button>
							</div>
						</form>
					</div>

					<div class="photos-grid" id="photosGrid">
						<!-- Photos will be loaded here -->
					</div>
				</section>



						<h3>Управление афишей</h3>
						<button class="btn btn-primary" onclick="showAddEventForm()">
							+ Добавить событие
						</button>
					</div>

					<div id="addEventForm" class="form-container" style="display: none">
						<h4>Добавить/Редактировать событие</h4>
						<form onsubmit="saveEvent(event)">
							<input type="hidden" id="eventId" />
							<div class="form-row">
								<div class="form-group">
									<label>Категория</label>
									<select id="eventCategory" required>
										<option value="">Выберите категорию</option>
										<option value="Концерты">Концерты</option>
										<option value="Театр">Театр</option>
										<option value="Выставки">Выставки</option>
										<option value="Фестивали">Фестивали</option>
									</select>
								</div>
								<div class="form-group">
									<label>Название</label>
									<input
										type="text"
										id="eventTitle"
										required
										placeholder="Название события"
									/>
								</div>
							</div>
							<div class="form-row">
								<div class="form-group">
									<label>Дата</label>
									<input type="date" id="eventDate" required />
								</div>
								<div class="form-group">
									<label>Время</label>
									<input type="time" id="eventTime" />
								</div>
								<div class="form-group">
									<label>Длительность</label>
									<select id="eventDuration">
										<option value="">Выберите...</option>
										<option value="1 ч">1 ч</option>
										<option value="1 ч 15 мин">1 ч 15 мин</option>
										<option value="1 ч 30 мин">1 ч 30 мин</option>
										<option value="1 ч 45 мин">1 ч 45 мин</option>
										<option value="2 ч">2 ч</option>
										<option value="2 ч 15 мин">2 ч 15 мин</option>
										<option value="2 ч 30 мин">2 ч 30 мин</option>
										<option value="2 ч 45 мин">2 ч 45 мин</option>
										<option value="3 ч">3 ч</option>
										<option value="3 ч 15 мин">3 ч 15 мин</option>
										<option value="3 ч 30 мин">3 ч 30 мин</option>
										<option value="3 ч 45 мин">3 ч 45 мин</option>
										<option value="4 ч">4 ч</option>
									</select>
								</div>
							</div>

							<div class="form-row">
								<div class="form-group">
									<label>Возраст</label>
									<select id="eventAge">
										<option value="0+">0+</option>
										<option value="6+">6+</option>
										<option value="12+">12+</option>
										<option value="16+">16+</option>
										<option value="18+">18+</option>
									</select>
								</div>
								<div class="form-group">
									<label>Жанр</label>
									<input type="text" id="eventGenre" placeholder="Классика" />
								</div>
								<div class="form-group">
									<label>Вместимость</label>
									<div class="input-suffix-wrapper">
										<input type="number" id="eventCapacity" placeholder="500" />
										<span class="suffix">мест</span>
									</div>
								</div>
								<div class="form-group">
									<label>Стоимость</label>
									<div class="input-suffix-wrapper">
										<input type="number" id="eventPrice" placeholder="1500" />
										<span class="suffix">₽</span>
									</div>
								</div>
							</div>

							<div class="form-row">
								<div class="form-group">
									<label>Место проведения</label>
									<input
										type="text"
										id="eventLocation"
										placeholder="Концертный зал"
									/>
								</div>
								<div class="form-group">
									<label>Ссылка на билет (Купить)</label>
									<input
										type="text"
										id="eventTicketUrl"
										placeholder="https://..."
									/>
								</div>
							</div>

							<div class="form-group">
								<label>Описание</label>
								<textarea
									id="eventDescription"
									placeholder="Описание события"
								></textarea>
							</div>

							<div class="form-group">
								<label>Участники</label>
								<textarea
									id="eventParticipants"
									placeholder="Список участников..."
									style="min-height: 60px"
								></textarea>
							</div>

							<div class="form-group">
								<label>Изображение (афиша)</label>
								<input type="file" id="eventFile" accept="image/*" />
							</div>
							<div class="form-actions">
								<button type="submit" class="btn btn-primary">Сохранить</button>
								<button
									type="button"
									class="btn btn-secondary"
									onclick="hideAddEventForm()"
								>
									Отмена
								</button>
							</div>
						</form>
					</div>

					<div class="table-container">
						<table class="data-table">
							<thead>
								<tr>
									<th>Фото</th>
									<th>Дата</th>
									<th>Название</th>
									<th>Место</th>
									<th>Действия</th>
								</tr>
							</thead>
							<tbody id="eventsTableBody">
								<!-- Events will be loaded here -->
							</tbody>
						</table>
					</div>
				</section>



					<div class="form-container">
						<form onsubmit="saveFooter(event)">
							<div id="footerLinksContainer">
								<!-- Footer links will be loaded here -->
							</div>
							<button
								type="button"
								class="btn btn-secondary"
								onclick="addFooterLink()"
								style="margin-bottom: 15px"
							>
								+ Добавить ссылку
							</button>
							<br />
							<button type="submit" class="btn btn-primary">
								Сохранить Footer
							</button>
						</form>
					</div>
				</section>

				<!-- Social Links Section -->
				<section id="social" class="content-section">
					<div class="section-header">
						<h3>Управление социальными сетями</h3>
						<button class="btn btn-primary" onclick="showAddSocialForm()">
							+ Добавить соцсеть
						</button>
					</div>

					<div id="addSocialForm" class="form-container" style="display: none">
						<h4>Добавить/Редактировать соцсеть</h4>
						<form onsubmit="saveSocialLink(event)">
							<input type="hidden" id="socialId" />
							<div class="form-group">
								<label>Название</label>
								<select id="socialName" required>
									<option value="">Выберите...</option>
									<option value="Instagram">Instagram</option>
									<option value="Telegram">Telegram</option>
									<option value="X">X (Twitter)</option>
									<option value="YouTube">YouTube</option>
								</select>
							</div>
							<div class="form-group">
								<label>URL</label>
								<input
									type="url"
									id="socialUrl"
									required
									placeholder="https://..."
								/>
							</div>
							<div class="form-group">
								<label>Порядок</label>
								<input type="number" id="socialOrder" value="0" min="0" />
							</div>
							<div class="form-group">
								<label>
									<input type="checkbox" id="socialActive" checked />
									Активна
								</label>
							</div>
							<div class="form-actions">
								<button type="submit" class="btn btn-primary">Сохранить</button>
								<button
									type="button"
									class="btn btn-secondary"
									onclick="hideAddSocialForm()"
								>
									Отмена
								</button>
							</div>
						</form>
					</div>

					<div class="table-container">
						<table class="data-table">
							<thead>
								<tr>
									<th>Название</th>
									<th>URL</th>
									<th>Порядок</th>
									<th>Статус</th>
									<th>Действия</th>
								</tr>
							</thead>
							<tbody id="socialLinksTableBody">
								<!-- Social links will be loaded here -->
							</tbody>
						</table>
					</div>
				</section>

				<!-- Ticket Link Section -->
				<section id="tickets" class="content-section">
					<h3>Ссылка на покупку билетов</h3>
					<div class="form-container">
						<form onsubmit="saveTicketLink(event)">
							<div class="form-group">
								<label>URL билетов</label>
								<input
									type="url"
									id="ticketUrl"
									placeholder="https://..."
									required
								/>
							</div>
							<div class="form-group">
								<label>Текст кнопки</label>
								<input type="text" id="ticketLabel" value="Купить билеты" />
							</div>
							<div class="form-group">
								<label>
									<input type="checkbox" id="ticketActive" checked />
									Активна
								</label>
							</div>
							<button type="submit" class="btn btn-primary">Сохранить</button>
						</form>
					</div>
				</section>

				<!-- Contact Forms Section -->
				<section id="contactforms" class="content-section">
					<div class="section-header">
						<h3>Заявки "Связь с нами"</h3>
					</div>
					<div class="table-container">
						<table class="data-table">
							<thead>
								<tr>
									<th>Дата</th>
									<th>Имя</th>
									<th>Email</th>
									<th>Телефон</th>
									<th>Тема</th>
									<th>Статус</th>
									<th>Действия</th>
								</tr>
							</thead>
							<tbody id="contactFormsTableBody">
								<!-- Contact forms will be loaded here -->
							</tbody>
						</table>
					</div>
				</section>

				<!-- Stats Section -->
				<section id="stats" class="content-section">
					<h3>Статистика сайта</h3>
					<div class="stats-grid">
						<div class="stat-card large">
							<div class="stat-icon">📅</div>
							<div class="stat-info">
								<h3>Сегодня</h3>
								<p class="stat-number" id="statsToday">0</p>
								<small>посещений</small>
							</div>
						</div>
						<div class="stat-card large">
							<div class="stat-icon">📊</div>
							<div class="stat-info">
								<h3>Всего</h3>
								<p class="stat-number" id="statsTotal">0</p>
								<small>посещений</small>
							</div>
						</div>
					</div>
					<div style="margin-top: 20px; text-align: center">
						<button class="btn btn-danger" onclick="resetStats()">
							⚠️ Сбросить всю статистику
						</button>
					</div>
				</section>



					<div class="form-container">
						<form onsubmit="saveContacts(event)">
							<div class="form-group">
								<label>Email</label>
								<input
									type="email"
									id="contactEmail"
									placeholder="info@example.com"
								/>
							</div>
							<div class="form-group">
								<label>Телефон</label>
								<input type="text" id="contactPhone" placeholder="+7..." />
							</div>
							<div class="form-group">
								<label>Адрес</label>
								<input type="text" id="contactAddress" placeholder="Адрес" />
							</div>
							<button type="submit" class="btn btn-primary">
								Сохранить контакты
							</button>
						</form>
					</div>
				</section>

				<!-- Backup Section -->
				<section id="backup" class="content-section">
					<h3>Резервное копирование</h3>
					<div class="welcome-card">
						<h3>Скачать резервную копию базы данных</h3>
						<p>
							Нажмите кнопку ниже, чтобы скачать файл базы данных
							(juggler.sqlite). Это позволит вам восстановить данные в случае
							сбоя.
						</p>
						<div style="margin-top: 20px">
							<button class="btn btn-primary" onclick="downloadBackup()">
								💾 Скачать базу данных
							</button>
						</div>
					</div>
				</section>
			</main>
		</div>

		<!-- Notification Container -->
		<div id="notification-container" class="notification-container"></div>

		<!-- Custom Confirm Modal -->
		<div id="confirmModal" class="custom-modal-overlay">
			<div class="custom-modal">
				<h3 id="confirmTitle">Подтверждение</h3>
				<p id="confirmMessage">Вы уверены?</p>
				<div class="custom-modal-actions">
					<button class="btn btn-secondary" onclick="closeConfirmModal(false)">
						Отмена
					</button>
					<button class="btn btn-primary" onclick="closeConfirmModal(true)">
						Да, удалить
					</button>
				</div>
			</div>
		</div>

		<!-- Crop Modal -->
		<div id="cropModal" class="custom-modal-overlay">
			<div class="custom-modal" style="width: 90%; max-width: 800px">
				<h3>Кадрирование изображения</h3>
				<div
					class="img-container"
					style="max-height: 500px; margin-bottom: 20px"
				>
					<img id="imageToCrop" src="" style="max-width: 100%" />
				</div>
				<div class="custom-modal-actions">
					<button class="btn btn-secondary" onclick="closeCropModal()">
						Отмена
					</button>
					<button class="btn btn-primary" onclick="saveCrop()">Обрезать</button>
				</div>
			</div>
		</div>

		<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
		<!-- auth.js уже загружен в head -->
		<script src="js/admin.js"></script>
		<script>
			// Check authentication on page load
			checkAuth()
		</script>
	</body>
</html>
